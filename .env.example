# ─── Berglunds Byggtjänst Östersund — Environment Variables ───
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# ─── Site ───────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://berglundsbyggtjanst.se
NEXT_PUBLIC_EXPERIMENT_MODE=false

# ─── OpenRouter (Chat + RAG LLM) ───────────────────────────
# Get your key from https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ─── Google Embedding 2 (Vector Embeddings) ────────────────
# SEPARATE from OpenRouter — get from https://aistudio.google.com/apikey
# Used by: src/lib/embeddings.ts
GOOGLE_EMBEDDING_API_KEY=

# ─── Pinecone (Vector Database) ────────────────────────────
# Get your key from https://pinecone.io
# Used by: src/lib/pinecone.ts, src/scripts/ingest-seed-projects.ts
PINECONE_API_KEY=

# ─── Vercel Blob (Image Uploads) ────────────────────────────
# Get your token from https://vercel.com/dashboard
# Used by: src/app/api/upload-image/route.ts
BLOB_READ_WRITE_TOKEN=

# ─── Resend (Transactional Email) ──────────────────────────
# Get your key from https://resend.com
RESEND_API_KEY=
